#!/usr/bin/env bash

dirname="$PWD"

# wezterm isn't in Ubuntu's default repos — add the official apt source
if [ ! -f /etc/apt/sources.list.d/wezterm.list ]; then
	curl -fsSL https://apt.fury.io/wez/gpg.key | sudo gpg --yes --dearmor -o /usr/share/keyrings/wezterm-fury.gpg
	echo 'deb [signed-by=/usr/share/keyrings/wezterm-fury.gpg] https://apt.fury.io/wez/ * *' | sudo tee /etc/apt/sources.list.d/wezterm.list
	sudo chmod 644 /usr/share/keyrings/wezterm-fury.gpg
	sudo apt update
fi

# wezterm-nightly conflicts with the stable wezterm package — drop stable if it's installed
if dpkg -l wezterm 2>/dev/null | grep -q '^ii'; then
	sudo apt remove -y wezterm
fi

sudo apt install -y \
	curl \
	wget \
	xclip \
	vim \
	tmux \
	git \
	git-cola \
	aptitude \
	silversearcher-ag \
	postgresql-client\
	meld \
	openvpn-systemd-resolved \
	wezterm-nightly \
	pipx \
	unzip \
	;

# pipx-installed CLI tools
pipx list --short 2>/dev/null | grep -q '^frogmouth ' || pipx install frogmouth

# JetBrainsMono Nerd Font (used by wezterm)
if ! fc-list | grep -q "JetBrainsMono Nerd Font"; then
	tmpdir=$(mktemp -d)
	curl -fsSL -o "$tmpdir/JetBrainsMono.zip" \
		https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip
	mkdir -p ~/.local/share/fonts/JetBrainsMonoNerdFont
	unzip -q -o "$tmpdir/JetBrainsMono.zip" -d ~/.local/share/fonts/JetBrainsMonoNerdFont
	rm -rf "$tmpdir"
	fc-cache -f ~/.local/share/fonts
fi

export NVM_DIR="$HOME/.nvm";

if [ ! -d "$NVM_DIR" ]; then
	(
	  git clone https://github.com/nvm-sh/nvm.git "$NVM_DIR"
	  cd "$NVM_DIR"
	  git checkout `git describe --abbrev=0 --tags --match "v[0-9]*" $(git rev-list --tags --max-count=1)`
	) && \. "$NVM_DIR/nvm.sh"
fi

mkdir -p ~/.config

for file in ./bash/*; do
	name=$(echo "$file" | grep -o '[^\/]*$');
	ln -sf "$dirname/bash/$name" "$HOME/.bash_$name"
done

ln -sf $dirname/vimrc ~/.vimrc
ln -sf $dirname/gitconfig ~/.gitconfig
ln -sf $dirname/gitignore_global ~/.gitignore_global
ln -sf $dirname/ackrc ~/.ackrc
ln -sf $dirname/psqlrc ~/.psqlrc
ln -sf $dirname/tmux.conf ~/.tmux.conf
ln -sf $dirname/rtorrent.rc ~/.rtorrent.rc

ln -snf $dirname/bin ~/bin

mkdir -p ~/.config/nvim
ln -sf $dirname/nvim/init.lua ~/.config/nvim/init.lua
ln -snf $dirname/nvim/lua ~/.config/nvim/lua
ln -snf $dirname/nvim/plugin ~/.config/nvim/plugin
ln -snf $dirname/nvim/after ~/.config/nvim/after

mkdir -p ~/.config/wezterm
ln -sf $dirname/wezterm/wezterm.lua ~/.config/wezterm/wezterm.lua
ln -snf $dirname/wezterm/colors ~/.config/wezterm/colors

# Firefox custom applications and icons
mkdir -p ~/.local/share/applications
mkdir -p ~/.local/share/icons
mkdir -p ~/.local/bin
cp $dirname/firefox/bin/firefox-*.sh ~/.local/bin/
cp $dirname/firefox/applications/firefox_work.desktop ~/.local/share/applications/
cp $dirname/firefox/applications/firefox_personal.desktop ~/.local/share/applications/
cp $dirname/firefox/icons/firefox-work.png ~/.local/share/icons/
cp $dirname/firefox/icons/firefox-personal.png ~/.local/share/icons/
update-desktop-database ~/.local/share/applications 2>/dev/null || true

source ~/.bash_profile


if [ -x "$dirname/private/update" ]; then
	source $dirname/private/update
fi

